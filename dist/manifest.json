{
  "manifest_version": 3,
  "name": "Mastodon Feed Listener",
  "version": "2.0.0",
  "description": "监控 Mastodon 用户 Feed，支持登录和发布功能",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "identity"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon.svg",
      "48": "icons/icon.svg",
      "128": "icons/icon.svg"
    }
  },
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
