{
  "manifest_version": 3,
  "name": "Mastodon Feed Listener",
  "version": "1.0.0",
  "description": "监控 Mastodon 用户 Feed，当有新内容时发送通知",
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "*://*.mastodon.social/*",
    "*://*.mastodon.online/*",
    "*://*.fosstodon.org/*",
    "*://*.tech.lgbt/*",
    "*://*/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon.svg",
      "48": "icons/icon.svg",
      "128": "icons/icon.svg"
    }
  },
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  }
}
